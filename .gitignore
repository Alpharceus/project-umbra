# Virtual environment
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.pytest_cache/

# Editor / tooling
.claude/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Runtime data (keep templates, ignore runtime writes)
data/devices.json
data/layouts/

# Logs
*.log
logs/

# Node (if frontend tooling is added later)
node_modules/
package-lock.json

# Dev tooling / build artifacts (not needed in the repo)
# (comments must be on their own line — gitignore treats trailing text as part of the pattern)
# headless JS checker (needs py_mini_racer; dev-only)
jscheck.py
# PyInstaller spec (regenerated by the build command)
*.spec
*.exe
# per-machine config override (keep the IP out of the repo)
data/config.local.json
